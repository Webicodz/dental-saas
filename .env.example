# Dental Practice Management System - Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# APPLICATION
# ============================================
NODE_ENV=production
APP_URL=http://localhost:3000
PORT=3000
API_PORT=4000

# ============================================
# DATABASE
# ============================================
# PostgreSQL connection string
DATABASE_URL=postgresql://dental_user:your_secure_password_here@postgres:5432/dental_db

# Database password (used in docker-compose)
DB_PASSWORD=your_secure_password_here

# ============================================
# REDIS CACHE
# ============================================
REDIS_URL=redis://redis:6379

# ============================================
# SECURITY
# ============================================
# Generate with: openssl rand -base64 64
JWT_SECRET=your_jwt_secret_key_minimum_64_characters_long_change_this
SESSION_SECRET=your_session_secret_key_minimum_64_characters_long_change_this

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:4000

# ============================================
# LICENSE (Enter after installation)
# ============================================
LICENSE_KEY=
ACTIVATION_EMAIL=

# ============================================
# CLINIC INFORMATION
# ============================================
CLINIC_NAME=Your Dental Clinic
CLINIC_EMAIL=info@yourclinic.com
CLINIC_PHONE=+1-555-123-4567
CLINIC_ADDRESS=123 Main Street, City, State 12345

# Branding
CLINIC_LOGO_URL=/uploads/logo.png
PRIMARY_COLOR=#2563eb
SECONDARY_COLOR=#7c3aed

# ============================================
# TIMEZONE & LOCALE
# ============================================
TIMEZONE=America/New_York
LOCALE=en-US
CURRENCY=USD
DATE_FORMAT=MM/DD/YYYY
TIME_FORMAT=12h

# ============================================
# AI - OPENAI (For Chatbot)
# ============================================
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=1000

# ============================================
# AI - ANTHROPIC CLAUDE (Alternative to OpenAI)
# ============================================
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# ============================================
# VOICE - DEEPGRAM (Speech-to-Text)
# ============================================
# Get your key from: https://console.deepgram.com/
DEEPGRAM_API_KEY=

# ============================================
# VOICE - ELEVENLABS (Text-to-Speech)
# ============================================
# Get your key from: https://elevenlabs.io/
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ============================================
# SMS & VOICE CALLS - TWILIO
# ============================================
# Get your credentials from: https://console.twilio.com/
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ============================================
# EMAIL - SENDGRID
# ============================================
# Get your key from: https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=noreply@yourclinic.com
SENDGRID_FROM_NAME=Your Dental Clinic

# ============================================
# FILE UPLOADS
# ============================================
MAX_FILE_SIZE=50 # MB
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=/uploads

# ============================================
# FEATURES CONFIGURATION
# ============================================
# Enable/disable features (true/false)
FEATURE_AI_CHATBOT=true
FEATURE_VOICE_AGENT=true
FEATURE_SMS_REMINDERS=true
FEATURE_EMAIL_REMINDERS=true
FEATURE_ONLINE_BOOKING=true
FEATURE_PATIENT_PORTAL=true
FEATURE_MULTI_LOCATION=false

# ============================================
# APPOINTMENT SETTINGS
# ============================================
DEFAULT_APPOINTMENT_DURATION=30 # minutes
REMINDER_HOURS_BEFORE=24
CONFIRMATION_HOURS_BEFORE=48
MAX_APPOINTMENTS_PER_DAY=50

# ============================================
# BACKUP SETTINGS
# ============================================
BACKUP_ENABLED=true
BACKUP_PATH=/backups
BACKUP_RETENTION_DAYS=30
BACKUP_TIME=02:00 # 2 AM daily

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW=15 # minutes
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# LOGGING
# ============================================
LOG_LEVEL=info # debug, info, warn, error
LOG_PATH=/logs
LOG_MAX_SIZE=10 # MB
LOG_MAX_FILES=10

# ============================================
# SESSION
# ============================================
SESSION_DURATION=24 # hours
SESSION_REFRESH=true

# ============================================
# MONITORING (Optional)
# ============================================
SENTRY_DSN=
SENTRY_ENVIRONMENT=production

# Google Analytics (Optional)
GA_TRACKING_ID=

# ============================================
# WEBHOOKS (Optional)
# ============================================
WEBHOOK_SECRET=
WEBHOOK_TIMEOUT=30000 # milliseconds

# ============================================
# ADVANCED SETTINGS
# ============================================
# Database connection pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# Redis connection
REDIS_MAX_RETRIES=3
REDIS_RETRY_DELAY=1000 # milliseconds

# API timeout
API_TIMEOUT=30000 # milliseconds

# ============================================
# DEVELOPMENT ONLY (Remove in production)
# ============================================
# DEBUG=true
# SHOW_STACK_TRACE=true
